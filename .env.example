# ── Model providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=                  # Gemini Flash (Tier-0)

# ── LiteLLM gateway ────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=              # internal API key for the gateway
LITELLM_BASE_URL=http://localhost:4000

# ── Postgres + pgvector ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gearward:gearward@localhost:5432/gearward

# ── Redis (job queue) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Langfuse (tracing) ─────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── HubSpot (per-client OAuth tokens stored in Postgres; only your own portal here)
HUBSPOT_PRIVATE_APP_TOKEN=       # YOUR agency portal only

# ── Content publishing ─────────────────────────────────────────────────────────
HIGGSFIELD_API_KEY=

# ── Eval / CI ──────────────────────────────────────────────────────────────────
EVAL_MIN_AVERAGE=7.0             # gate threshold; block deploys below this
